{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++: GDB 调试",
            "type": "cppdbg",
            "request": "launch",
            "program": "${fileDirname}\\${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${fileDirname}",
            "environment": [],
            "externalConsole": true,  // 外部控制台，方便输入和查看
            "MIMode": "gdb",
            "miDebuggerPath": "D:\\LeStoreDownload\\winlibs\\mingw64\\bin\\gdb.exe",
            "miDebuggerArgs": "--silent",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "C/C++: g++.exe 生成活动文件"
        }
    ]
}